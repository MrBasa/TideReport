{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Deploy (development)",
      "type": "shell",
      "command": "fish",
      "args": ["-c", "fisher remove MrBasa/TideReport@v1 2>/dev/null; fisher remove \"${workspaceFolder}\" 2>/dev/null; fisher install \"${workspaceFolder}\""],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "echo": true
      }
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "fish",
      "args": ["--no-config", "scripts/run_tests_isolated.fish"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "echo": true
      }
    }
  ]
}
